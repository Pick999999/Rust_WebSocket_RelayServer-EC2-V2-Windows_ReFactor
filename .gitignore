# Generated by Cargo
# will have compiled files and executables
**/target/
**/target*/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
# Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which can after a rustc update
*.pdb

# Environment Variables (Ignore secret configs)
.env
.env.local
.env.*
!.env.example

# Secret Keys
*firebase-adminsdk*.json

# Logs and backups
logs/
*.log
backup/
build_error.txt

# App Specific Data (Trade history, dynamically generated files)
tradeHistory/
tickhistory/
tradeSignal.json

# IDEs and Local History
.vscode/
.idea/
.lh/
*.swp

# OS
.DS_Store
Thumbs.db