# Application Authentication
APP_USER=admin
APP_PASSWORD=password

# Google Cloud Firestore Configuration
# Set your GCP Project ID to enable Firestore integration
# If not set, Firestore will be disabled
FIRESTORE_PROJECT_ID=your-firebase-project-id

# Note: For Firestore authentication, you also need to set 
# GOOGLE_APPLICATION_CREDENTIALS environment variable to point
# to your service account JSON key file:
# Example: GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account-key.json
